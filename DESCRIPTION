Package: jaspAhabsHarpoon
Type: Package
Title: Detecting Type I Errors via Bayes/NHST Conflict
Version: 0.1
Date: 2026-05-05
Authors@R: c(
    person("Evan", "Strasdin", email = "evn.strsdn@pm.me", role = c("aut", "cre")),
    person("Puneet", "Velidi", role = "aut"),
    person("Zhengxiao", "Wei", role = "aut"),
    person(given = "Farouk S.", family = "Nathoo", role = "aut")
